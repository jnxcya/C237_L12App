<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Add Workout</title>


</head>

<body>

    <div class="container mt-4">

        <h1 class="text-center">Add Workout</h1>

        <form action="/confirmworkout" method="POST">

            <!-- DAY -->
            <div class="mb-3">
                <label class="form-label">Workout Day</label>

                <input type="number" name="Day" class="form-control" placeholder="Enter workout day" min="1" required>
            </div>

            <!-- TIMING -->
            <div class="mb-3">
                <label class="form-label">Workout Timing</label>

                <select name="Timing" class="form-control" required>
                    <option value="Morning">Morning</option>
                    <option value="Afternoon">Afternoon</option>
                    <option value="Evening">Evening</option>
                </select>
            </div>

            <!-- MUSCLE GROUPS -->
            <div class="mb-3">

                <label class="form-label">
                    Select Muscle Groups
                </label>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Cardio" class="form-check-input">
                    <label class="form-check-label">Cardio</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Biceps" class="form-check-input">
                    <label class="form-check-label">Biceps</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Shoulders" class="form-check-input">
                    <label class="form-check-label">Shoulders</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Chest" class="form-check-input">
                    <label class="form-check-label">Chest</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Back" class="form-check-input">
                    <label class="form-check-label">Back</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Legs" class="form-check-input">
                    <label class="form-check-label">Legs</label>
                </div>

                <div class="form-check">
                    <input type="checkbox" name="MuscleGroups" value="Abs" class="form-check-input">
                    <label class="form-check-label">Abs</label>
                </div>

            </div>

            <!-- NOTES -->
            <div class="mb-3">
                <label class="form-label">Workout Notes</label>

                <textarea name="Notes" class="form-control" placeholder="Enter workout notes">
            </textarea>
            </div>

            <div class="text-center">
                <button type="submit" class="btn btn-primary">
                    Add Workout
                </button>
            </div>

        </form>

    </div>

</body>

</html>